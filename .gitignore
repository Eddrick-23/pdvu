# --- Build Artifacts (CMake) ---
# Ignore all build directories (Debug, Release, etc.)
cmake-build-*/
build/
bin/
lib/

# Ignore C++ Object files and executables
*.o
*.obj
*.dylib
*.so
*.dll
*.exe

# The specific binary name for your project
pdvu

# CMake generation artifacts (if run in root)
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# --- IDE Settings (CLion / JetBrains) ---
.idea/

.vscode/

# --- macOS System Files ---
.DS_Store

# Ignore temporary test PDFs
/samples

# Ignore unit test logs
/Testing

# Ignore benchmark artifacts
/benchmark/output
/benchmark/__pycache__
